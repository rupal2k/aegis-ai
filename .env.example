# Database Configuration
POSTGRES_USER=aegis_user
POSTGRES_PASSWORD=aegis_pass_change_me_in_production
POSTGRES_DB=aegis_db
DATABASE_URL=postgresql://aegis_user:aegis_pass_change_me_in_production@db:5432/aegis_db

# JWT Configuration
SECRET_KEY=your_secret_key_here_min_32_chars_strong
HASH_SALT=your_hash_salt_here

# Environment
ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8501

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000

# Security
SECURE_COOKIES=false
HTTPS_ONLY=false

# Session Configuration  
SESSION_TIMEOUT_HOURS=8

# Logging
LOG_LEVEL=INFO
